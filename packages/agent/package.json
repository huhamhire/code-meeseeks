{
  "name": "@meebox/agent",
  "version": "0.0.0",
  "private": true,
  "description": "High-level Agent core: Agent-directory loading (SOUL/AGENTS/MEMORY/USER + rules), context assembly, template scaffolding; orchestration and AutoPilot wired in later (see docs/arch/02-agent/01-agent.md)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests --max-warnings=0"
  },
  "nx": {
    "targets": {
      "typecheck": { "cache": true },
      "test": { "cache": true },
      "lint": { "cache": true }
    }
  },
  "dependencies": {
    "@meebox/rules": "*",
    "@meebox/shared": "*"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
