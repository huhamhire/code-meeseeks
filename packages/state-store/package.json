{
  "name": "@meebox/state-store",
  "version": "0.0.0",
  "private": true,
  "description": "Atomic JSON-file state store + interface for meebox (M5 may swap to SQLite)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src tests --max-warnings=0"
  },
  "nx": {
    "targets": {
      "typecheck": {
        "cache": true
      },
      "test": {
        "cache": true
      },
      "lint": {
        "cache": true
      }
    }
  }
}
