{
  "name": "@pr-pilot/logger",
  "version": "0.0.0",
  "private": true,
  "description": "Logging factory (pino + rolling files) for pr-pilot",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "nx": {
    "targets": {
      "typecheck": { "cache": true },
      "lint": { "cache": true }
    }
  },
  "dependencies": {
    "pino": "^9.5.0",
    "pino-roll": "^3.0.0"
  }
}
