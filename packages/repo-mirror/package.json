{
  "name": "@pr-pilot/repo-mirror",
  "version": "0.0.0",
  "private": true,
  "description": "Local git mirror manager (partial bare clone + fetch + per-repo serialization)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings=0"
  },
  "nx": {
    "targets": {
      "typecheck": { "cache": true },
      "test": { "cache": true },
      "lint": { "cache": true }
    }
  },
  "dependencies": {
    "@pr-pilot/shared": "*",
    "simple-git": "^3.36.0"
  }
}
