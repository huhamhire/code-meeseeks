{
  "name": "@pr-pilot/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "pr-pilot Electron desktop app",
  "author": {
    "name": "huhamhire",
    "email": "me@huhamhire.com"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src --max-warnings=0",
    "prepare:pragent": "node scripts/assemble-pragent-runtime.mjs",
    "pack": "npm run prepare:pragent && electron-vite build && electron-builder --dir",
    "dist": "npm run prepare:pragent && electron-vite build && electron-builder"
  },
  "nx": {
    "targets": {
      "build": {
        "cache": true,
        "outputs": [
          "{projectRoot}/out"
        ]
      },
      "typecheck": {
        "cache": true
      },
      "lint": {
        "cache": true
      },
      "prepare:pragent": {
        "cache": false,
        "outputs": [
          "{projectRoot}/vendor"
        ]
      },
      "pack": {
        "cache": false,
        "outputs": [
          "{projectRoot}/release"
        ]
      },
      "dist": {
        "cache": false,
        "outputs": [
          "{projectRoot}/release"
        ]
      }
    }
  },
  "dependencies": {
    "@iconify-json/material-icon-theme": "^1.2.66",
    "@iconify/react": "^5.2.1",
    "@monaco-editor/react": "^4.7.0",
    "@pr-pilot/config": "*",
    "@pr-pilot/logger": "*",
    "@pr-pilot/platform-bitbucket-server": "*",
    "@pr-pilot/poller": "*",
    "@pr-pilot/pr-agent-bridge": "*",
    "@pr-pilot/repo-mirror": "*",
    "@pr-pilot/rules": "*",
    "@pr-pilot/shared": "*",
    "@pr-pilot/state-store": "*",
    "anser": "^2.3.5",
    "monaco-editor": "^0.55.0",
    "pino": "^9.5.0",
    "pino-roll": "^3.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "sass": "^1.100.0",
    "tar": "^7.4.3",
    "undici": "^6.21.1",
    "vite": "^7.3.0"
  }
}
