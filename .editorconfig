root = true

[*]
indent_style = space
indent_size = 2
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

[*.md]
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2

# JS / TS（与 prettier 对齐：2 空格）
[*.{js,jsx,ts,tsx,cjs,mjs}]
indent_size = 2

# 样式表（CSS / SCSS / Sass）：2 空格
[*.{css,scss,sass}]
indent_size = 2

# Python（嵌入式 shim / 构建脚本）：PEP 8 用 4 空格，行宽 88（对齐 black）
[*.py]
indent_size = 4
max_line_length = 88
