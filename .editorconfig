root = true

[*]
indent_style = space
indent_size = 2
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

[*.md]
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2

[*.{js,jsx,ts,tsx,cjs,mjs}]
indent_size = 2

[*.{css,scss,sass}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[{Makefile,makefile,GNUmakefile,*.mk}]
indent_style = tab
tab_width = 4
